        "query": "SELECT e FROM Estudiante e WHERE UPPER(e.primerNombre) LIKE UPPER(:primerNombre) ESCAPE '\\' OR UPPER(e.primerApellido) LIKE UPPER(:primerApellido) ESCAPE '\\' OR UPPER(e.numeroDocumento) LIKE UPPER(:numeroDocumento) ESCAPE '\\'"
      }
    },
