    {
      "name": "findByPrimerNombreContainingIgnoreCaseOrPrimerApellidoContainingIgnoreCaseOrNumeroDocumentoContainingIgnoreCase",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Estudiante> com.pruebasaber.app.repository.EstudianteRepository.findByPrimerNombreContainingIgnoreCaseOrPrimerApellidoContainingIgnoreCaseOrNumeroDocumentoContainingIgnoreCase(java.lang.String,java.lang.String,java.lang.String)",
