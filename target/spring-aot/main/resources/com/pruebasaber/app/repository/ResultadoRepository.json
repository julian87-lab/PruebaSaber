{
  "name": "com.pruebasaber.app.repository.ResultadoRepository",
  "module": "JPA",
  "type": "IMPERATIVE",
  "methods": [
    {
      "name": "buscarConEstudiante",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Resultado> com.pruebasaber.app.repository.ResultadoRepository.buscarConEstudiante(java.lang.String)",
      "query": {
        "query": "    SELECT r\n    FROM Resultado r\n    JOIN FETCH r.estudiante e\n    WHERE LOWER(e.primerNombre) LIKE LOWER(CONCAT('%', :texto, '%'))\n       OR LOWER(e.primerApellido) LIKE LOWER(CONCAT('%', :texto, '%'))\n       OR LOWER(e.numeroDocumento) LIKE LOWER(CONCAT('%', :texto, '%'))\n    ORDER BY r.puntajeGlobal DESC\n"
      }
    },
    {
      "name": "buscarPorPeriodoConEstudiante",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Resultado> com.pruebasaber.app.repository.ResultadoRepository.buscarPorPeriodoConEstudiante(java.lang.String,java.lang.String)",
      "query": {
        "query": "    SELECT r\n    FROM Resultado r\n    JOIN FETCH r.estudiante e\n    WHERE r.periodo = :periodo\n      AND (\n            LOWER(e.primerNombre) LIKE LOWER(CONCAT('%', :texto, '%'))\n         OR LOWER(e.primerApellido) LIKE LOWER(CONCAT('%', :texto, '%'))\n         OR LOWER(e.numeroDocumento) LIKE LOWER(CONCAT('%', :texto, '%'))\n      )\n    ORDER BY r.puntajeGlobal DESC\n"
      }
    },
    {
      "name": "existsByEstudianteIdAndPeriodoAndNumeroRegistro",
      "signature": "public abstract boolean com.pruebasaber.app.repository.ResultadoRepository.existsByEstudianteIdAndPeriodoAndNumeroRegistro(java.lang.Long,java.lang.String,java.lang.String)",
      "query": {
        "query": "SELECT r.id FROM Resultado r WHERE r.estudiante.id = :estudianteId AND r.periodo = :periodo AND r.numeroRegistro = :numeroRegistro"
      }
    },
    {
      "name": "findAllConEstudiante",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Resultado> com.pruebasaber.app.repository.ResultadoRepository.findAllConEstudiante()",
      "query": {
        "query": "    SELECT r\n    FROM Resultado r\n    JOIN FETCH r.estudiante e\n    ORDER BY r.puntajeGlobal DESC\n"
      }
    },
    {
      "name": "findByEstudianteId",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Resultado> com.pruebasaber.app.repository.ResultadoRepository.findByEstudianteId(java.lang.Long)",
      "query": {
        "query": "    SELECT r\n    FROM Resultado r\n    JOIN FETCH r.estudiante e\n    WHERE e.id = :estudianteId\n    ORDER BY r.periodo DESC, r.puntajeGlobal DESC\n"
      }
    },
    {
      "name": "findByPeriodoConEstudiante",
      "signature": "public abstract java.util.List<com.pruebasaber.app.models.Resultado> com.pruebasaber.app.repository.ResultadoRepository.findByPeriodoConEstudiante(java.lang.String)",
      "query": {
        "query": "    SELECT r\n    FROM Resultado r\n    JOIN FETCH r.estudiante e\n    WHERE r.periodo = :periodo\n    ORDER BY r.puntajeGlobal DESC\n"
      }
    },
